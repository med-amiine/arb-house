# BCV Keeper Configuration

# Blockchain
ARB_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_API_KEY
CHAIN_ID=421614

# Keeper Wallet (MUST BE THE AUTHORIZED KEEPER ADDRESS)
# This address must match the keeper set in the vault contract
KEEPER_PRIVATE_KEY=0x...
KEEPER_ADDRESS=0x...

# Contract Addresses
VAULT_ADDRESS=0x5fced2ffc59401d5a3D2439C7b997E7bcCF85Ff8

# Feature Flags
MOCK_MODE=false
ENABLE_EVENT_LISTENER=true
ENABLE_WITHDRAWAL_PROCESSOR=true
ENABLE_BALANCE_SYNC=true

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./keeper.db
# DATABASE_URL=postgresql://user:pass@localhost/bcv_keeper

# Service Intervals
SYNC_INTERVAL_SECONDS=300
WITHDRAWAL_POLL_INTERVAL_SECONDS=10

# Logging
LOG_LEVEL=INFO
