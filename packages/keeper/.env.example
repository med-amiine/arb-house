# Keeper Environment Variables

# === Blockchain Connection ===
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
CHAIN_ID=42161

# === Keeper Identity ===
KEEPER_PRIVATE_KEY=0x
KEEPER_ADDRESS=0x

# === Vault Contract ===
VAULT_ADDRESS=0x

# === Giza SDK ===
GIZA_API_KEY=
GIZA_AGENT_1_ID=
GIZA_AGENT_2_ID=
GIZA_AGENT_3_ID=

# === Database ===
DATABASE_URL=postgresql://user:pass@localhost:5432/bcv_keeper
REDIS_URL=redis://localhost:6379/0

# === Service Config ===
LOG_LEVEL=INFO
SYNC_INTERVAL_SECONDS=300
WITHDRAWAL_POLL_INTERVAL_SECONDS=10
REBALANCE_THRESHOLD_BPS=500
MAX_SYNC_STALE_MINUTES=720

# === Monitoring ===
SENTRY_DSN=
